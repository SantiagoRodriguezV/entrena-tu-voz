@@ -34,3 +34,10 @@ target_link_libraries(tunerengine
     ReactAndroid::reactnative
     fbjni::fbjni
 )
+
+# Android 15+ 16 KB page size: NDK r27 still defaults to 4 KB ELF alignment.
+# Without this, libtunerengine.so fails the device compatibility check.
+target_link_options(tunerengine PRIVATE
+  "-Wl,-z,max-page-size=16384"
+  "-Wl,-z,common-page-size=16384"
+)
