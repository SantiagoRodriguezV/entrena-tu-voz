{
  "expo": {
    "name": "SCREAM.io",
    "slug": "entrena-tu-voz",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.entrenatuvoz.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "La app necesita el micrófono para analizar tu voz durante los ejercicios vocales."
      }
    },
    "android": {
      "package": "com.entrenatuvoz.app",
      "permissions": [
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1F1F1F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-dev-client",
      [
        "expo-audio",
        {
          "microphonePermission": "La app necesita el micrófono para analizar tu voz durante los ejercicios vocales."
        }
      ],
      [
        "react-native-tuner-engine",
        {
          "microphonePermission": "La app necesita el micrófono para analizar tu voz durante los ejercicios vocales."
        }
      ]
    ]
  }
}
